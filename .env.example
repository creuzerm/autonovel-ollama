# Anthropic API key (optional if using LiteLLM/Ollama)
ANTHROPIC_API_KEY=sk-ant-...

# LiteLLM / Remote Ollama Setup
# If using LiteLLM proxy to bridge to remote Ollama:
LITELLM_BASE_URL=http://localhost:4000
OPENAI_API_KEY=sk-dummy

# Writer model (used for drafting and revision)
# For Ollama, use e.g., ollama/qwen3.6 or ollama/gemma2:27b
AUTONOVEL_WRITER_MODEL=claude-sonnet-4-6

# Judge model (used for evaluation — should differ from writer)
AUTONOVEL_JUDGE_MODEL=claude-sonnet-4-6

# Review model (Opus — deep prose-level analysis, used in Phase 3b)
AUTONOVEL_REVIEW_MODEL=claude-opus-4-6

# API base URL (Ignored if LITELLM_BASE_URL is set)
AUTONOVEL_API_BASE_URL=https://api.anthropic.com

# fal.ai key for image generation (Nano Banana 2)
FAL_KEY=your-fal-api-key-here

# ElevenLabs API key for audiobook generation
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
